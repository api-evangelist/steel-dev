          "name": "Create a browser session",
          "request": {
            "name": "Create a browser session",
            "description": {
              "content": "Launch a new cloud browser session; returns websocketUrl (CDP), debugUrl, and sessionViewerUrl.",
              "type": "text/plain"
            },
            "url": {
              "path": ["v1", "sessions"],
              "host": ["{{baseUrl}}"],
              "query": [],
              "variable": []
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"proxyUrl\": \"<string>\",\n  \"blockAds\": true,\n  \"solveCaptcha\": false,\n  \"timezone\": \"<string>\",\n  \"dimensions\": { \"width\": 1280, \"height\": 800 }\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": []
